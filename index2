<script>
  const DEFAULT_DECIMALS = 2;

  function setText(id, txt) {
    document.getElementById(id).textContent = txt;
  }

  function clearText(id) {
    document.getElementById(id).textContent = "";
  }

  function parseNum(id) {
    const v = document.getElementById(id).value;
    if (v === "" || v === null) return null;
    const n = Number(v);
    return Number.isFinite(n) ? n : null;
  }

  function formatWith(decimals, value) {
    if (!Number.isFinite(value)) return String(value);
    const d = Math.max(0, Math.min(10, Number(decimals) || DEFAULT_DECIMALS));
    return value.toFixed(d);
  }

  function isNonNegative(n) {
    return typeof n === "number" && Number.isFinite(n) && n >= 0;
  }

  function openAll() {
    document.querySelectorAll("details.calc").forEach(d => d.open = true);
  }

  function closeAll() {
    document.querySelectorAll("details.calc").forEach(d => d.open = false);
  }

  function resetAll() {
    clearExpr();
    resetStats();
  }

  /* -------- Enhanced General Calculator -------- */

  function appendExpr(s) {
    const el = document.getElementById("expr");
    el.value = (el.value || "") + s;
    el.focus();
  }

  function backspaceExpr() {
    const el = document.getElementById("expr");
    el.value = (el.value || "").slice(0, -1);
    el.focus();
  }

  function clearExpr() {
    document.getElementById("expr").value = "";
    document.getElementById("exprResult").textContent = "-";
  }

  function transformExpression(raw) {
    let expr = raw.trim();

    // Percent handling: 25% -> (25/100)
    expr = expr.replace(/(\d+(\.\d+)?)\s*%/g, "($1/100)");

    // Constants
    expr = expr.replace(/\bpi\b/g, "Math.PI");
    expr = expr.replace(/\be\b/g, "Math.E");

    // Functions
    expr = expr.replace(/\bsqrt\s*\(/g, "Math.sqrt(");
    expr = expr.replace(/\babs\s*\(/g, "Math.abs(");
    expr = expr.replace(/\bln\s*\(/g, "Math.log(");
    expr = expr.replace(/\blog\s*\(/g, "Math.log10(");

    // Power operator a^b -> a**b
    expr = expr.replace(/\^/g, "**");

    return expr;
  }

  function computeExpr() {
    const raw = (document.getElementById("expr").value || "").trim();
    if (!raw) {
      setText("exprResult", "Enter an expression.");
      return;
    }

    if (!/^[0-9+\-*/().,%\s^a-zA-Z]+$/.test(raw)) {
      setText("exprResult", "Invalid characters.");
      return;
    }

    const transformed = transformExpression(raw);

    try {
      const val = Function(`"use strict"; return (${transformed});`)();
      if (!Number.isFinite(val)) {
        setText("exprResult", "Result undefined.");
        return;
      }
      setText("exprResult", String(val));
    } catch (e) {
      setText("exprResult", "Check your expression.");
    }
  }

  document.addEventListener("keydown", (e) => {
    const active = document.activeElement;
    if (active && active.id === "expr" && e.key === "Enter") {
      e.preventDefault();
      computeExpr();
    }
  });

  /* -------- Statistical Tools -------- */

  // erf approximation
  function erf(x) {
    const sign = x >= 0 ? 1 : -1;
    x = Math.abs(x);

    const a1 = 0.254829592;
    const a2 = -0.284496736;
    const a3 = 1.421413741;
    const a4 = -1.453152027;
    const a5 = 1.061405429;
    const p = 0.3275911;

    const t = 1 / (1 + p * x);
    const y = 1 - (((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * t * Math.exp(-x * x));
    return sign * y;
  }

  function normalCDF(z) {
    return 0.5 * (1 + erf(z / Math.sqrt(2)));
  }

  // inverse normal CDF approximation by Peter John Acklam
  function inverseNormalCDF(p) {
    if (!(p > 0 && p < 1)) return NaN;

    const a = [
      -3.969683028665376e+01,
       2.209460984245205e+02,
      -2.759285104469687e+02,
       1.383577518672690e+02,
      -3.066479806614716e+01,
       2.506628277459239e+00
    ];

    const b = [
      -5.447609879822406e+01,
       1.615858368580409e+02,
      -1.556989798598866e+02,
       6.680131188771972e+01,
      -1.328068155288572e+01
    ];

    const c = [
      -7.784894002430293e-03,
      -3.223964580411365e-01,
      -2.400758277161838e+00,
      -2.549732539343734e+00,
       4.374664141464968e+00,
       2.938163982698783e+00
    ];

    const d = [
       7.784695709041462e-03,
       3.224671290700398e-01,
       2.445134137142996e+00,
       3.754408661907416e+00
    ];

    const plow = 0.02425;
    const phigh = 1 - plow;
    let q, r;

    if (p < plow) {
      q = Math.sqrt(-2 * Math.log(p));
      return (((((c[0] * q + c[1]) * q + c[2]) * q + c[3]) * q + c[4]) * q + c[5]) /
             ((((d[0] * q + d[1]) * q + d[2]) * q + d[3]) * q + 1);
    }

    if (phigh < p) {
      q = Math.sqrt(-2 * Math.log(1 - p));
      return -(((((c[0] * q + c[1]) * q + c[2]) * q + c[3]) * q + c[4]) * q + c[5]) /
               ((((d[0] * q + d[1]) * q + d[2]) * q + d[3]) * q + 1);
    }

    q = p - 0.5;
    r = q * q;
    return (((((a[0] * r + a[1]) * r + a[2]) * r + a[3]) * r + a[4]) * r + a[5]) * q /
           (((((b[0] * r + b[1]) * r + b[2]) * r + b[3]) * r + b[4]) * r + 1);
  }

  function runZFromSL() {
    const p = parseNum("slInput");
    const d = document.getElementById("roundStats1").value;

    if (p === null) {
      setText("zFromSLResult", "Enter a service level.");
      return;
    }
    if (!(p > 0 && p < 1)) {
      setText("zFromSLResult", "Service level must be between 0 and 1.");
      return;
    }

    const z = inverseNormalCDF(p);
    setText("zFromSLResult", `z = ${formatWith(d, z)}`);
  }

  function runSLFromZ() {
    const z = parseNum("zInput");
    const d = document.getElementById("roundStats2").value;

    if (z === null) {
      setText("slFromZResult", "Enter a z-score.");
      return;
    }

    const p = normalCDF(z);
    setText("slFromZResult", `Service level = ${formatWith(d, p)} (${formatWith(2, p * 100)}%)`);
  }

  function runStandardize() {
    const x = parseNum("stdX");
    const mean = parseNum("stdMean");
    const sd = parseNum("stdSD");
    const d = document.getElementById("roundStats3").value;

    if (x === null || mean === null || sd === null) {
      setText("standardizeResult", "Enter x, mean, and standard deviation.");
      return;
    }
    if (!(sd > 0)) {
      setText("standardizeResult", "Standard deviation must be > 0.");
      return;
    }

    const z = (x - mean) / sd;
    setText("standardizeResult", `z = ${formatWith(d, z)}`);
  }

  function parseDataList(text) {
    return text
      .split(/[\s,]+/)
      .map(s => s.trim())
      .filter(s => s !== "")
      .map(Number)
      .filter(n => Number.isFinite(n));
  }

  function mean(arr) {
    return arr.reduce((a, b) => a + b, 0) / arr.length;
  }

  function sampleSD(arr) {
    if (arr.length < 2) return NaN;
    const m = mean(arr);
    const sumSq = arr.reduce((acc, v) => acc + (v - m) ** 2, 0);
    return Math.sqrt(sumSq / (arr.length - 1));
  }

  function populationSD(arr) {
    if (arr.length < 1) return NaN;
    const m = mean(arr);
    const sumSq = arr.reduce((acc, v) => acc + (v - m) ** 2, 0);
    return Math.sqrt(sumSq / arr.length);
  }

  function runDataStats() {
    const raw = document.getElementById("dataList").value || "";
    const arr = parseDataList(raw);

    if (arr.length === 0) {
      setText("dataStatsResult", "Enter at least one valid number.");
      return;
    }

    const m = mean(arr);
    const sSample = sampleSD(arr);
    const sPop = populationSD(arr);

    let out = `n = ${arr.length} | Mean = ${formatWith(4, m)}`;
    out += ` | Sample SD = ${Number.isFinite(sSample) ? formatWith(4, sSample) : "N/A"}`;
    out += ` | Population SD = ${Number.isFinite(sPop) ? formatWith(4, sPop) : "N/A"}`;

    setText("dataStatsResult", out);
  }

  function resetStats() {
    document.getElementById("slInput").value = "";
    document.getElementById("roundStats1").value = "4";
    setText("zFromSLResult", "-");

    document.getElementById("zInput").value = "";
    document.getElementById("roundStats2").value = "4";
    setText("slFromZResult", "-");

    document.getElementById("stdX").value = "";
    document.getElementById("stdMean").value = "";
    document.getElementById("stdSD").value = "";
    document.getElementById("roundStats3").value = "4";
    setText("standardizeResult", "-");

    document.getElementById("dataList").value = "";
    setText("dataStatsResult", "-");
  }

  /* -------- Accordion behavior -------- */
  document.querySelectorAll("details.calc").forEach(d => {
    d.addEventListener("toggle", () => {
      if (d.open) {
        document.querySelectorAll("details.calc").forEach(other => {
          if (other !== d) other.open = false;
        });
      }
    });
  });
</script>
</body>
</html>
